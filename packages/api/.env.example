# Database (required)
DATABASE_URL=postgresql://analytics:analytics@postgres:5432/analytics

# API server
PORT=3001

# Seed endpoint secret (required to call POST /api/seed)
SEED_SECRET=your-secret-here

# GeoIP lookup (optional — download from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data)
# GEOLITE2_PATH=/path/to/GeoLite2-City.mmdb
